    car:       { amount: 700000,  rate: 9.5,  tenure: 7,  maxAmount: 3000000,  maxTenure: 7  },
    personal:  { amount: 500000,  rate: 14,   tenure: 5,  maxAmount: 1500000,  maxTenure: 5  },
    education: { amount: 1000000, rate: 9.5,  tenure: 10, maxAmount: 4000000,  maxTenure: 15 },
  };

  // ── LOAN TYPE TABS ────────────────────────────────────────
  document.querySelectorAll('.loan-tab[data-type]').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.loan-tab[data-type]').forEach(t => {
        t.classList.remove('active'); t.setAttribute('aria-selected','false');
      });
      tab.classList.add('active'); tab.setAttribute('aria-selected','true');
      const p = presets[tab.dataset.type];
      document.getElementById('loanAmount').value = p.amount;
      document.getElementById('interestRate').value = p.rate;
      document.getElementById('loanTenure').value = p.tenure;
      document.getElementById('loanAmountRange').max = p.maxAmount;
      document.getElementById('loanAmountRange').value = p.amount;
      document.getElementById('loanTenureRange').max = p.maxTenure;
      document.getElementById('loanTenureRange').value = p.tenure;
      document.getElementById('interestRateRange').value = p.rate;
      syncSliders();
      calculate();
    });
  });

  // ── TENURE UNIT TOGGLE ────────────────────────────────────
  const btnYears = document.getElementById('tenureYears');
  const btnMonths = document.getElementById('tenureMonths');
  const tenureInput = document.getElementById('loanTenure');
  const tenureUnit = document.getElementById('tenureUnit');

  btnYears.addEventListener('click', () => {
    if (!inYears) {
      inYears = true;
      tenureInput.value = Math.round(tenureInput.value / 12);
      tenureInput.max = 30;
      tenureUnit.textContent = 'Years';
      document.getElementById('loanTenureRange').max = 30;
      document.getElementById('loanTenureRange').value = tenureInput.value;
      document.querySelector('.range-labels:last-of-type').innerHTML = '<span>1 yr</span><span>30 yrs</span>';
    }
    btnYears.classList.add('active'); btnYears.setAttribute('aria-pressed','true');
    btnMonths.classList.remove('active'); btnMonths.setAttribute('aria-pressed','false');
    calculate();
  });

  btnMonths.addEventListener('click', () => {
    if (inYears) {
      inYears = false;
      tenureInput.value = tenureInput.value * 12;
      tenureInput.max = 360;
      tenureUnit.textContent = 'Months';
      document.getElementById('loanTenureRange').max = 360;
      document.getElementById('loanTenureRange').value = tenureInput.value;
    }
    btnMonths.classList.add('active'); btnMonths.setAttribute('aria-pressed','true');
    btnYears.classList.remove('active'); btnYears.setAttribute('aria-pressed','false');
    calculate();
  });

  // ── SLIDER ↔ INPUT SYNC ───────────────────────────────────
  function syncSliders() {
    ['loanAmount', 'interestRate', 'loanTenure'].forEach(id => {
      const input = document.getElementById(id);
      const range = document.getElementById(id + 'Range');
      const pct = ((input.value - range.min) / (range.max - range.min)) * 100;
      range.style.setProperty('--pct', pct + '%');
    });
  }

  ['loanAmount', 'interestRate', 'loanTenure'].forEach(id => {
    const input = document.getElementById(id);
    const range = document.getElementById(id + 'Range');

    input.addEventListener('input', () => {
      range.value = input.value;
      syncSliders();
      calculate();
    });
    range.addEventListener('input', () => {
      input.value = range.value;
      syncSliders();
      calculate();
    });
  });

  // ── CORE CALCULATION ──────────────────────────────────────
  function calculate() {
    const P = parseFloat(document.getElementById('loanAmount').value) || 0;
    const annualRate = parseFloat(document.getElementById('interestRate').value) || 0;
    const tenureRaw = parseFloat(document.getElementById('loanTenure').value) || 0;
    const n = inYears ? tenureRaw * 12 : tenureRaw;
    const r = annualRate / 12 / 100;

    if (P <= 0 || n <= 0 || annualRate <= 0) return;

    // EMI formula
    const emi = r === 0 ? P / n : (P * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const totalPayment = emi * n;
    const totalInterest = totalPayment - P;
    const interestPct = Math.round((totalInterest / totalPayment) * 100);
    const principalPct = 100 - interestPct;

    // Update summary
    document.getElementById('emiDisplay').textContent = fmt(emi);
    document.getElementById('emiSub').textContent = `for ${n} months (${inYears ? tenureRaw + ' years' : Math.round(n/12*10)/10 + ' years'})`;
    document.getElementById('resPrincipal').textContent = fmt(P);
    document.getElementById('resInterest').textContent = fmt(totalInterest);
    document.getElementById('resTotal').textContent = fmt(totalPayment);
    document.getElementById('legendPrincipal').textContent = fmt(P);
    document.getElementById('legendInterest').textContent = fmt(totalInterest);
    document.getElementById('interestPct').textContent = interestPct + '%';

    // Donut chart
    const circumference = 2 * Math.PI * 54; // 339.3
    const principalDash = (principalPct / 100) * circumference;
    const interestDash = (interestPct / 100) * circumference;
    const principalArc = document.getElementById('principalArc');
    const interestArc  = document.getElementById('interestArc');
    principalArc.setAttribute('stroke-dasharray', circumference);
    principalArc.setAttribute('stroke-dashoffset', circumference - principalDash);
    interestArc.setAttribute('stroke-dasharray', circumference);
    interestArc.setAttribute('stroke-dashoffset', circumference - interestDash);
    // Offset interest arc to start after principal
    interestArc.style.transform = `rotate(${principalPct * 3.6}deg)`;
    interestArc.style.transformOrigin = '70px 70px';

    // Build schedule
    schedule = [];
    let balance = P;
    for (let month = 1; month <= n; month++) {
      const interestComp = balance * r;
      const principalComp = emi - interestComp;
      balance = Math.max(0, balance - principalComp);
      schedule.push({
        month,
        emi: Math.round(emi),
        principal: Math.round(principalComp),
        interest: Math.round(interestComp),
        balance: Math.round(balance)
      });
    }

    // Show cards
    document.getElementById('resultsCard').classList.add('show');
    document.getElementById('amortCard').classList.add('show');

    // Render table
    renderTable(document.getElementById('viewMonthly').classList.contains('active') ? 'monthly' : 'yearly');
  }

  // ── TABLE RENDER ──────────────────────────────────────────
  function renderTable(mode) {
    const tbody = document.getElementById('amortBody');
    tbody.innerHTML = '';

    if (mode === 'monthly') {
      schedule.forEach(row => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>Month ${row.month}</td>
          <td>${row.emi.toLocaleString('en-IN')}</td>
          <td class="td-principal">${row.principal.toLocaleString('en-IN')}</td>
          <td class="td-interest">${row.interest.toLocaleString('en-IN')}</td>
          <td class="td-balance">${row.balance.toLocaleString('en-IN')}</td>`;
        tbody.appendChild(tr);
      });
    } else {
      // Group by year
      const years = {};
      schedule.forEach(row => {
        const yr = Math.ceil(row.month / 12);
        if (!years[yr]) years[yr] = { emi: 0, principal: 0, interest: 0, balance: 0 };
        years[yr].emi += row.emi;
        years[yr].principal += row.principal;
        years[yr].interest += row.interest;
        years[yr].balance = row.balance;
      });
      Object.entries(years).forEach(([yr, data]) => {
        const tr = document.createElement('tr');
        tr.classList.add('year-row');
        tr.innerHTML = `
          <td>Year ${yr}</td>
          <td>${data.emi.toLocaleString('en-IN')}</td>
          <td class="td-principal">${data.principal.toLocaleString('en-IN')}</td>
          <td class="td-interest">${data.interest.toLocaleString('en-IN')}</td>
          <td class="td-balance">${data.balance.toLocaleString('en-IN')}</td>`;
        tbody.appendChild(tr);
      });
    }
  }

  // ── VIEW TOGGLE (monthly/yearly) ─────────────────────────
  document.getElementById('viewMonthly').addEventListener('click', () => {
    document.getElementById('viewMonthly').classList.add('active');
    document.getElementById('viewMonthly').setAttribute('aria-pressed','true');
    document.getElementById('viewYearly').classList.remove('active');
    document.getElementById('viewYearly').setAttribute('aria-pressed','false');
    renderTable('monthly');
  });
  document.getElementById('viewYearly').addEventListener('click', () => {
    document.getElementById('viewYearly').classList.add('active');
    document.getElementById('viewYearly').setAttribute('aria-pressed','true');
    document.getElementById('viewMonthly').classList.remove('active');
    document.getElementById('viewMonthly').setAttribute('aria-pressed','false');
    renderTable('yearly');
  });

  // ── CALCULATE BUTTON ─────────────────────────────────────
  document.getElementById('calcBtn').addEventListener('click', calculate);

  // ── FAQ ACCORDION ─────────────────────────────────────────
  document.querySelectorAll('.faq-q').forEach(q => {
    const activate = () => {
      const item = q.closest('.faq-item');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-q').setAttribute('aria-expanded','false');
      });
      if (!isOpen) { item.classList.add('open'); q.setAttribute('aria-expanded','true'); }
    };
    q.addEventListener('click', activate);
    q.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); } });
  });

  // ── INIT ─────────────────────────────────────────────────
  syncSliders();
  calculate();
</script>

</body>
</html>
