  <style>
    :root {
      --saffron:    #FF6B00;
      --saffron-lt: #FF8C38;
      --turmeric:   #F5A623;
      --ivory:      #FDF6EC;
      --cream:      #FAF0DC;
      --bark:       #2C1A0E;
      --bark-lt:    #5C3D1E;
      --jade:       #1A6B4A;
      --jade-lt:    #2A9467;
      --sand:       #E8D5B0;
      --muted:      #8C7B6B;
      --white:      #FFFFFF;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--ivory); color: var(--bark); overflow-x: hidden; }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        radial-gradient(circle at 10% 10%, rgba(255,107,0,0.05) 0%, transparent 50%),
        radial-gradient(circle at 90% 90%, rgba(26,107,74,0.04) 0%, transparent 50%),
        url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23FF6B00' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none; z-index: 0;
    }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(253,246,236,0.92); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--sand);
      padding: 0 5%; display: flex; align-items: center; justify-content: space-between; height: 64px;
    }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-mark { width: 38px; height: 38px; background: var(--saffron); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: 'Yatra One', cursive; color: white; font-size: 18px; box-shadow: 0 2px 8px rgba(255,107,0,0.3); }
    .logo-text { font-family: 'Yatra One', cursive; font-size: 22px; color: var(--bark); }
    .logo-text span { color: var(--saffron); }
    .nav-links { display: flex; gap: 32px; list-style: none; }
    .nav-links a { text-decoration: none; color: var(--bark-lt); font-size: 15px; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--saffron); }
    .nav-cta { background: var(--saffron); color: white !important; padding: 8px 20px; border-radius: 8px; font-weight: 600 !important; }

    /* ── BREADCRUMB ── */
    .breadcrumb { position: relative; z-index: 1; padding: 14px 5%; font-size: 13px; color: var(--muted); max-width: 1200px; margin: 0 auto; }
    .breadcrumb a { color: var(--muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--saffron); }
    .breadcrumb span { margin: 0 6px; }

    /* ── PAGE LAYOUT ── */
    .page-layout {
      position: relative; z-index: 1;
      max-width: 1200px; margin: 0 auto;
      padding: 0 5% 80px;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 32px;
      align-items: start;
    }

    /* ── TOOL HEADER ── */
    .tool-header { margin-bottom: 28px; }
    .tool-tag { display: inline-flex; align-items: center; gap: 7px; background: rgba(26,107,74,0.08); color: var(--jade); font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; padding: 5px 12px; border-radius: 100px; margin-bottom: 14px; }
    .tool-tag .dot { width: 6px; height: 6px; background: var(--jade); border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .tool-header h1 { font-family: 'Yatra One', cursive; font-size: clamp(26px, 4vw, 42px); color: var(--bark); line-height: 1.15; margin-bottom: 10px; }
    .tool-header p { font-size: 16px; color: var(--muted); line-height: 1.6; }

    /* ── LOAN TYPE TABS ── */
    .loan-tabs { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
    .loan-tab {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 20px; border-radius: 100px;
      border: 1.5px solid var(--sand);
      background: var(--white);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px; font-weight: 500;
      color: var(--bark-lt); cursor: pointer;
      transition: all 0.2s;
    }
    .loan-tab:hover { border-color: var(--saffron); color: var(--saffron); }
    .loan-tab.active { background: var(--saffron); color: white; border-color: var(--saffron); }
    .loan-tab .tab-icon { font-size: 16px; }

    /* ── CALCULATOR CARD ── */
    .calc-card {
      background: var(--white);
      border: 1px solid var(--sand);
      border-radius: 20px;
      padding: 32px;
      box-shadow: 0 4px 24px rgba(44,26,14,0.07);
      margin-bottom: 24px;
    }

    .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }

    .input-group { display: flex; flex-direction: column; gap: 8px; }
    .input-group label { font-size: 13px; font-weight: 600; color: var(--bark-lt); }
    .input-group label span { color: var(--muted); font-weight: 400; }

    .input-with-unit {
      display: flex; align-items: stretch;
      border: 1.5px solid var(--sand);
      border-radius: 12px; overflow: hidden;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: var(--ivory);
    }
    .input-with-unit:focus-within { border-color: var(--saffron); box-shadow: 0 0 0 3px rgba(255,107,0,0.1); }

    .input-unit {
      background: var(--cream);
      border-right: 1.5px solid var(--sand);
      padding: 0 14px;
      display: flex; align-items: center;
      font-size: 14px; font-weight: 600;
      color: var(--bark-lt);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .input-unit.right { border-right: none; border-left: 1.5px solid var(--sand); }

    .input-with-unit input {
      flex: 1; border: none; outline: none;
      padding: 13px 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px; color: var(--bark);
      background: transparent;
      width: 100%;
    }
    .input-with-unit input::-webkit-inner-spin-button,
    .input-with-unit input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }

    /* RANGE SLIDER */
    .range-wrap { margin-top: 8px; }
    input[type="range"] {
      -webkit-appearance: none;
      width: 100%; height: 5px;
      border-radius: 3px;
      background: linear-gradient(to right, var(--saffron) 0%, var(--saffron) var(--pct, 50%), var(--sand) var(--pct, 50%), var(--sand) 100%);
      outline: none; cursor: pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px; height: 18px;
      border-radius: 50%;
      background: var(--saffron);
      box-shadow: 0 2px 6px rgba(255,107,0,0.4);
      cursor: pointer;
      border: 2px solid white;
    }
    .range-labels { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-top: 5px; }

    /* CALCULATE BUTTON */
    .btn-calculate {
      width: 100%;
      background: var(--saffron);
      color: white;
      border: none; border-radius: 12px;
      padding: 16px;
      font-family: 'DM Sans', sans-serif;
      font-size: 16px; font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 16px rgba(255,107,0,0.3);
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-calculate:hover { background: var(--saffron-lt); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,0,0.35); }
    .btn-calculate:active { transform: translateY(0); }

    /* ── RESULTS SUMMARY ── */
    .results-card {
      background: var(--white);
      border: 1px solid var(--sand);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(44,26,14,0.07);
      margin-bottom: 24px;
      display: none;
      animation: fadeUp 0.4s ease;
    }
    .results-card.show { display: block; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }

    .results-header {
      background: linear-gradient(135deg, var(--bark) 0%, var(--bark-lt) 100%);
      padding: 28px 32px;
    }
    .results-header h2 { font-family: 'Yatra One', cursive; font-size: 18px; color: rgba(255,255,255,0.6); margin-bottom: 6px; }
    .emi-big { font-family: 'Yatra One', cursive; font-size: clamp(36px, 5vw, 54px); color: white; }
    .emi-sub { font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 4px; }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .summary-item {
      padding: 22px 24px;
      border-right: 1px solid var(--sand);
      text-align: center;
    }
    .summary-item:last-child { border-right: none; }
    .summary-label { font-size: 12px; font-weight: 600; color: var(--muted); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 6px; }
    .summary-value { font-family: 'Yatra One', cursive; font-size: 22px; }
    .sv-principal { color: var(--jade); }
    .sv-interest  { color: var(--saffron); }
    .sv-total     { color: var(--bark); }

    /* DONUT CHART */
    .chart-row {
      display: flex; align-items: center; gap: 32px;
      padding: 24px 28px;
      border-top: 1px solid var(--sand);
      flex-wrap: wrap;
    }
    .donut-wrap { flex-shrink: 0; position: relative; width: 140px; height: 140px; }
    .donut-wrap svg { transform: rotate(-90deg); }
    .donut-center {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center;
    }
    .donut-center .dc-pct { font-family: 'Yatra One', cursive; font-size: 22px; color: var(--bark); }
    .donut-center .dc-label { font-size: 11px; color: var(--muted); }

    .legend { display: flex; flex-direction: column; gap: 14px; }
    .legend-item { display: flex; align-items: center; gap: 10px; }
    .legend-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
    .ld-principal { background: var(--jade); }
    .ld-interest  { background: var(--saffron); }
    .legend-info { display: flex; flex-direction: column; }
    .legend-info .li-label { font-size: 12px; color: var(--muted); }
    .legend-info .li-val { font-size: 15px; font-weight: 600; color: var(--bark); }

    /* ── AMORTIZATION TABLE ── */
    .amort-card {
      background: var(--white);
      border: 1px solid var(--sand);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(44,26,14,0.07);
      margin-bottom: 24px;
      display: none;
    }
    .amort-card.show { display: block; }

    .amort-header {
      padding: 22px 28px;
      border-bottom: 1px solid var(--sand);
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 14px;
    }
    .amort-header h3 { font-family: 'Yatra One', cursive; font-size: 20px; color: var(--bark); }
    .amort-controls { display: flex; gap: 10px; }
    .amort-view-btn {
      background: var(--cream); border: 1.5px solid var(--sand);
      border-radius: 8px; padding: 7px 14px;
      font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
      color: var(--bark-lt); cursor: pointer; transition: all 0.2s;
    }
    .amort-view-btn.active, .amort-view-btn:hover { background: var(--saffron); color: white; border-color: var(--saffron); }

    .amort-table-wrap { overflow-x: auto; max-height: 420px; overflow-y: auto; }
    .amort-table-wrap::-webkit-scrollbar { width: 5px; height: 5px; }
    .amort-table-wrap::-webkit-scrollbar-track { background: var(--cream); }
    .amort-table-wrap::-webkit-scrollbar-thumb { background: var(--sand); border-radius: 3px; }

    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th { position: sticky; top: 0; background: var(--cream); padding: 12px 18px; text-align: right; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: var(--muted); white-space: nowrap; z-index: 2; }
    thead th:first-child { text-align: left; }
    tbody td { padding: 12px 18px; text-align: right; border-top: 1px solid rgba(232,213,176,0.5); color: var(--bark); }
    tbody td:first-child { text-align: left; font-weight: 600; }
    tbody tr:hover td { background: rgba(255,107,0,0.02); }
    tbody tr.year-row td { background: var(--cream); font-weight: 700; color: var(--bark); }
    tbody tr.year-row td:first-child { color: var(--saffron); }

    .td-principal { color: var(--jade) !important; font-weight: 600 !important; }
    .td-interest  { color: var(--saffron) !important; }
    .td-balance   { color: var(--bark-lt) !important; }

    .amort-note { padding: 14px 24px; font-size: 12px; color: var(--muted); border-top: 1px solid var(--sand); background: var(--cream); }

    /* ── ARTICLE & FAQ ── */
    .article-section { background: var(--white); border: 1px solid var(--sand); border-radius: 20px; padding: 32px; margin-bottom: 24px; }
    .article-section h2 { font-family: 'Yatra One', cursive; font-size: 24px; color: var(--bark); margin-bottom: 14px; }
    .article-section h3 { font-size: 18px; font-weight: 600; color: var(--bark); margin: 22px 0 10px; }
    .article-section p { font-size: 15px; color: var(--muted); line-height: 1.8; margin-bottom: 12px; }
    .article-section ul { padding-left: 20px; color: var(--muted); font-size: 15px; line-height: 1.8; margin-bottom: 12px; }
    .article-section table { font-size: 14px; }
    .article-section thead th { font-size: 12px; }
    .formula-box { background: var(--cream); border: 1.5px solid var(--sand); border-radius: 12px; padding: 18px 22px; margin: 16px 0; font-family: monospace; font-size: 15px; color: var(--bark-lt); line-height: 1.8; }
    .formula-box strong { color: var(--saffron); }

    .faq-section { margin-bottom: 24px; }
    .faq-section h2 { font-family: 'Yatra One', cursive; font-size: 24px; color: var(--bark); margin-bottom: 20px; }
    .faq-item { background: var(--white); border: 1px solid var(--sand); border-radius: 14px; margin-bottom: 10px; overflow: hidden; }
    .faq-q { padding: 18px 22px; font-size: 15px; font-weight: 600; color: var(--bark); cursor: pointer; display: flex; justify-content: space-between; align-items: center; user-select: none; }
    .faq-q:hover { color: var(--saffron); }
    .faq-icon { font-size: 22px; color: var(--muted); transition: transform 0.25s; flex-shrink: 0; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s; font-size: 14px; color: var(--muted); line-height: 1.75; }
    .faq-item.open .faq-a { max-height: 300px; padding: 0 22px 18px; }

    /* ── SIDEBAR ── */
    .sidebar { position: sticky; top: 80px; }
    .side-card { background: var(--white); border: 1px solid var(--sand); border-radius: 16px; padding: 22px; margin-bottom: 20px; }
    .side-card h4 { font-family: 'Yatra One', cursive; font-size: 17px; color: var(--bark); margin-bottom: 14px; }
    .side-links { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .side-links li a { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--bark-lt); font-size: 14px; padding: 8px 12px; border-radius: 8px; transition: background 0.15s, color 0.15s; }
    .side-links li a:hover { background: var(--cream); color: var(--saffron); }
    .side-links li a.current { background: rgba(255,107,0,0.08); color: var(--saffron); font-weight: 600; }
    .side-badge-live { font-size: 10px; font-weight: 700; background: rgba(26,107,74,0.1); color: var(--jade); padding: 2px 7px; border-radius: 100px; margin-left: auto; }
    .side-badge-soon { font-size: 10px; font-weight: 700; background: rgba(245,166,35,0.12); color: #8A6000; padding: 2px 7px; border-radius: 100px; margin-left: auto; }

    /* Rate Reference Table in Sidebar */
    .rate-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .rate-table th { text-align: left; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: var(--muted); padding: 6px 8px; border-bottom: 1px solid var(--sand); }
    .rate-table td { padding: 9px 8px; border-bottom: 1px solid rgba(232,213,176,0.4); color: var(--bark); font-size: 13px; }
    .rate-table tr:last-child td { border-bottom: none; }
    .rate-chip { display: inline-block; background: rgba(255,107,0,0.1); color: var(--saffron); font-weight: 700; padding: 2px 8px; border-radius: 100px; font-size: 12px; }

    /* ── FOOTER ── */
    footer { position: relative; z-index: 1; background: var(--bark); padding: 48px 5% 24px; }
